{
  "outputDirectory": "public",
  "rewrites": [
    { "source": "/p/:path*",     "destination": "https://pizzaedition.win/:path*" },
    { "source": "/ddg/:path*",   "destination": "https://lite.duckduckgo.com/:path*" },
    { "source": "/_next/:path*", "destination": "https://pizzaedition.win/_next/:path*" },
    { "source": "/:path*",       "destination": "https://pizzaedition.win/:path*" }
  ]
}
